{
  "theme": {
    "editor": {
      "background": "#FFFFFF",
      "font_family": "Monaco",
      "font_size": 11
    },
    "line_numbers": {
      "background": "#dcdcdc",
      "text": "#000000"
    },
    "current_line": {
      "background": "#ffffd0"
    },
    "status_bar": {
      "background": "#f5f5f5",
      "height": 24
    },
    "syntax_highlighting": {
      "keyword": "#0000FF",
      "string": "#A315AD",
      "number": "#098658",
      "comment": "#008000",
      "builtin": "#795E26",
      "decorator": "#800000",
      "class_def": "#267F99",
      "function_def": "#267F99"
    },
    "pair_highlighting": {
      "color": "#FFFD38"
    },
    "welcome": {
      "text_primary": "#000000",
      "text_secondary": "#888888",
      "divider": "#E0E0E0"
    },
    "tabs": {
      "strip_background": "#FFFFFF",
      "selected_background": "#CEE6FC",
      "unselected_background": "#FFFFFF",
      "border": "#D2D2D2",
      "selected_text": "#2386FB",
      "unselected_text": "#000000",
      "selected_close_hover_background": "#BBDCFB",
      "unselected_close_hover_background": "#F0F0F0",
      "separator": "#D2D2D2",
      "height": 30
    }
  },
  "editor": {
    "font": {
      "tab_size": 4
    },
    "line_numbers": {
      "enabled": true,
      "minimum_width": 15
    },
    "syntax_highlighting": {
      "enabled": true,
      "keywords": [
        "False", "None", "True", "and", "as", "assert", "async", "await",
        "break", "class", "continue", "def", "del", "elif", "else", "except",
        "finally", "for", "from", "global", "if", "import", "in", "is",
        "lambda", "nonlocal", "not", "or", "pass", "raise", "return", "try",
        "while", "with", "yield"
      ],
      "builtins": [
        "abs", "all", "any", "bin", "bool", "bytes", "callable", "chr", "dict",
        "dir", "divmod", "enumerate", "eval", "exec", "filter", "float", "format",
        "frozenset", "getattr", "globals", "hasattr", "hash", "help", "hex", "id",
        "input", "int", "isinstance", "issubclass", "iter", "len", "list", "locals",
        "map", "max", "min", "next", "object", "oct", "open", "ord", "pow",
        "print", "property", "range", "repr", "reversed", "round", "set",
        "setattr", "slice", "sorted", "staticmethod", "str", "sum", "super", "tuple",
        "type", "vars", "zip", "__import__"
      ]
    },
    "auto_indent": {
      "enabled": true,
      "pairs": {
        "(": ")",
        "[": "]",
        "{": "}",
        "\"": "\"",
        "'": "'"
      }
    },
    "auto_pairing": {
      "enabled": true,
      "pairs": {
        "(": ")",
        "[": "]",
        "{": "}",
        "\"": "\"",
        "'": "'"
      }
    }
  },
  "tasks": {
    "tasks": [
      {
        "name": "Run with Python",
        "command": "python3"
      }
    ]
  }
}